{
  "cols": [
    "step_id",
    "step_order",
    "op_type",
    "params_json",
    "enabled",
    "on_error",
    "note"
  ],
  "rows": [
    [
      "S1",
      "10",
      "read_csv",
      "{\"file\":\"2_purc_de_rat/raw/input.csv\",\"encoding\":\"auto\"}",
      "Y",
      "stop",
      "读取源数据"
    ],
    [
      "S2",
      "20",
      "filter",
      "{\"column\":\"是否内部供应商\",\"op\":\"!=\",\"value\":\"Y\"}",
      "Y",
      "stop",
      "剔除内部供应商=Y"
    ],
    [
      "S3",
      "30",
      "filter",
      "{\"column\":\"是否联动定价\",\"op\":\"!=\",\"value\":\"Y\"}",
      "Y",
      "stop",
      "剔除联动定价=Y"
    ],
    [
      "S4",
      "40",
      "calc",
      "{\"new_col\":\"过账日期_dt\",\"formula\":\"pd.to_datetime(df['物料凭证过账日期'], format='%Y%m%d')\"}",
      "Y",
      "stop",
      "转日期格式"
    ],
    [
      "S5",
      "50",
      "calc",
      "{\"new_col\":\"is_Q4\",\"formula\":\"(df['过账日期_dt'].dt.year == 2025) & (df['过账日期_dt'].dt.quarter == 4)\"}",
      "Y",
      "stop",
      "标记Q4记录"
    ],
    [
      "S6",
      "55",
      "calc",
      "{\"new_col\":\"未税采购金额RMB_num\",\"formula\":\"pd.to_numeric(df['未税采购金额RMB'], errors='coerce').fillna(0)\"}",
      "Y",
      "stop",
      "金额转数值"
    ],
    [
      "S7",
      "56",
      "calc",
      "{\"new_col\":\"入仓数量_num\",\"formula\":\"pd.to_numeric(df['入仓数量'], errors='coerce').fillna(0)\"}",
      "Y",
      "stop",
      "数量转数值"
    ],
    [
      "S8",
      "60",
      "calc",
      "{\"new_col\":\"has_Q4_flag\",\"formula\":\"df['物料编码'].map(df.groupby('物料编码')['is_Q4'].any()).map({True: 'Y', False: 'N'})\"}",
      "Y",
      "stop",
      "物料级别是否有Q4记录"
    ],
    [
      "S9",
      "70",
      "calc",
      "{\"new_col\":\"是否有2025年第四季度入仓记录\",\"formula\":\"df['has_Q4_flag']\"}",
      "Y",
      "stop",
      "重命名列"
    ],
    [
      "SAVE_FULL",
      "75",
      "write_csv",
      "{\"file\":\"output/full_detail.csv\",\"encoding\":\"utf-8-sig\"}",
      "Y",
      "stop",
      "保存明细备查"
    ],
    [
      "S10",
      "80",
      "calc",
      "{\"new_col\":\"基准价\",\"formula\":\"df.apply(lambda r: None, axis=1)\"}",
      "Y",
      "stop",
      "占位列"
    ],
    [
      "Q4_DATA",
      "90",
      "calc",
      "{\"new_col\":\"_q4_amt\",\"formula\":\"df['未税采购金额RMB_num'].where(df['is_Q4'], 0)\"}",
      "Y",
      "stop",
      "Q4金额"
    ],
    [
      "Q4_QTY",
      "95",
      "calc",
      "{\"new_col\":\"_q4_qty\",\"formula\":\"df['入仓数量_num'].where(df['is_Q4'], 0)\"}",
      "Y",
      "stop",
      "Q4数量"
    ],
    [
      "AGG",
      "100",
      "calc",
      "{\"new_col\":\"基准价\",\"formula\":\"df['物料编码'].map( (lambda d: ( (lambda q4a, q4q, alla, allq: pd.Series({ m: (q4a[m]/q4q[m] if q4q.get(m,0)!=0 else (alla[m]/allq[m] if allq.get(m,0)!=0 else 0)) for m in d['物料编码'].unique() }) )( d.groupby('物料编码')['_q4_amt'].sum(), d.groupby('物料编码')['_q4_qty'].sum(), d.groupby('物料编码')['未税采购金额RMB_num'].sum(), d.groupby('物料编码')['入仓数量_num'].sum() ) ))(df) )\"}",
      "Y",
      "stop",
      "计算基准价：Q4有记录用Q4均价，否则用全年均价"
    ],
    [
      "DEDUP",
      "110",
      "calc",
      "{\"new_col\":\"_keep\",\"formula\":\"~df.duplicated(subset=['物料编码'], keep='first')\"}",
      "Y",
      "stop",
      "去重标记"
    ],
    [
      "FILTER_DEDUP",
      "120",
      "filter",
      "{\"column\":\"_keep\",\"op\":\"==\",\"value\":true}",
      "Y",
      "stop",
      "保留唯一物料"
    ],
    [
      "SEL",
      "130",
      "select",
      "{\"columns\":[\"物料编码\",\"基准价\"]}",
      "Y",
      "stop",
      "只保留输出列"
    ],
    [
      "OUT",
      "140",
      "write_csv",
      "{\"file\":\"2_purc_de_rat/processed/物料基准价.csv\",\"encoding\":\"utf-8-sig\"}",
      "Y",
      "stop",
      "输出结果"
    ],
    [
      "END",
      "999",
      "end",
      "{}",
      "Y",
      "stop",
      "结束"
    ]
  ]
}