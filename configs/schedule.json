{
  "tasks": [
    {
      "id": "quickelt",
      "program": "quickELT.py",
      "enabled": true,
      "depends_on_files": ["config.json"]
    },
    {
      "id": "csvtohtml",
      "program": "csvtohtml.py",
      "args": ["data.csv"],
      "enabled": true,
      "depends_on": ["quickelt"]
    }
  ],
  "on_failure": "continue",
  "schedule": {
    "type": "interval",
    "minutes": 30,
    "run_on_start": true
  }
}